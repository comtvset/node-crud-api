{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "Node16",
    "types": ["node"],
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src", "*.ts"]
}
